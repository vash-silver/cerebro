<UserControl x:Class="MarvelHeroes.DpsMeter.Controls.LootScannerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A"
             Foreground="#CCFFFFFF"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="#FFFFB347"/>
            <Setter Property="Margin"     Value="0,12,0,4"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="Foreground"   Value="#77FFFFFF"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,2,0,8"/>
        </Style>
        <Style x:Key="AffixCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,2,12,2"/>
        </Style>
        <Style x:Key="CategoryHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#AABBCCDD"/>
            <Setter Property="Margin"     Value="0,8,0,2"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12,16,16">
        <StackPanel>
            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#DDFFFFFF"
                       Text="Cosmic Loot Scanner"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Configure what counts as a 'hunt match' -- pick the affixes you care about, set the threshold, and the diagnostic log will fire a special line whenever a drop matches.  Changes save instantly; no restart required."/>

            <!-- ── Master enable ──────────────────────────────────────────────────────── -->
            <CheckBox x:Name="EnabledCheck"
                      Style="{StaticResource AffixCheck}"
                      FontWeight="SemiBold"
                      FontSize="12"
                      Content="Enable hunt match alerts"
                      Margin="0,6,0,4"
                      Checked="EnabledCheck_OnChanged"
                      Unchecked="EnabledCheck_OnChanged"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="When off, drops still get scored / logged but the special 'HUNT MATCH' line is suppressed."/>

            <!-- ── Rarity filter ──────────────────────────────────────────────────────── -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Rarity"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RarityAnyRadio" GroupName="Rarity"
                             Content="Any rarity" Margin="0,0,16,0"
                             Foreground="#CCFFFFFF"
                             Checked="RarityRadio_OnChanged"/>
                <RadioButton x:Name="RarityCosmicRadio" GroupName="Rarity"
                             Content="Cosmic only (endgame)"
                             Foreground="#CCFFFFFF"
                             Checked="RarityRadio_OnChanged"/>
            </StackPanel>

            <!-- ── Min hits ───────────────────────────────────────────────────────────── -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Minimum matched affixes"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="MinHitsSlider" Grid.Column="0"
                        Minimum="1" Maximum="6"
                        SmallChange="1" LargeChange="1"
                        TickFrequency="1" TickPlacement="BottomRight"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="MinHitsSlider_OnChanged"/>
                <TextBlock x:Name="MinHitsReadout" Grid.Column="1"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           FontWeight="SemiBold" Foreground="#FFCC66"
                           MinWidth="40" TextAlignment="Right"
                           Text="2"/>
            </Grid>
            <TextBlock Style="{StaticResource HintText}"
                       Text="How many distinct selected affixes the item needs to count as a match.  2-3 catches 'good enough' rolls; 5-6 only fires on perfect rolls."/>

            <!-- ── Self filter ────────────────────────────────────────────────────────── -->
            <CheckBox x:Name="SelfOnlyCheck"
                      Style="{StaticResource AffixCheck}"
                      Content="Only items for my current hero"
                      Margin="0,8,0,4"
                      Checked="SelfOnlyCheck_OnChanged"
                      Unchecked="SelfOnlyCheck_OnChanged"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Filters by avatar prototype -- the item's EquippableBy must equal your active hero.  Turn off to see hunt matches for any hero (useful when shopping trades / collecting alts)."/>

            <!-- ── Alert sound ────────────────────────────────────────────────────────── -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Alert sound"/>
            <CheckBox x:Name="SoundEnabledCheck"
                      Style="{StaticResource AffixCheck}"
                      Content="Play sound on hunt match"
                      Checked="SoundEnabledCheck_OnChanged"
                      Unchecked="SoundEnabledCheck_OnChanged"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Fires a sound the moment a drop passes the hunt criteria.  Useful in noisy environments where you might miss the on-screen orange text."/>
            <Grid Margin="22,4,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#AAFFFFFF" FontSize="11"
                           Text="Sound:"/>
                <TextBox x:Name="SoundPathText" Grid.Column="1"
                         FontFamily="Consolas" FontSize="11"
                         Background="#1E1E1E" Foreground="#DDFFFFFF"
                         BorderBrush="#44FFFFFF" BorderThickness="1"
                         Padding="4,3" VerticalContentAlignment="Center"
                         IsReadOnly="True"
                         Text="(system default)"
                         ToolTip="WAV / MP3 / WMA / AAC supported.  Clear to fall back to the Windows asterisk."/>
                <Button Grid.Column="2" Content="Browse…" Margin="6,0,0,0"
                        Background="#222" BorderBrush="#44FFFFFF" BorderThickness="1"
                        Foreground="#DDFFFFFF" Padding="10,4" Cursor="Hand"
                        Click="BrowseSoundButton_Click"/>
                <Button Grid.Column="3" Content="Clear" Margin="6,0,0,0"
                        Background="#222" BorderBrush="#44FFFFFF" BorderThickness="1"
                        Foreground="#DDFFFFFF" Padding="10,4" Cursor="Hand"
                        Click="ClearSoundButton_Click"/>
            </Grid>
            <Grid Margin="22,6,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#AAFFFFFF" FontSize="11"
                           Text="Volume:"/>
                <Slider x:Name="SoundVolumeSlider" Grid.Column="1"
                        Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.2"
                        TickFrequency="0.1" TickPlacement="BottomRight"
                        IsSnapToTickEnabled="False" VerticalAlignment="Center"
                        ValueChanged="SoundVolumeSlider_OnChanged"/>
                <TextBlock x:Name="SoundVolumeReadout" Grid.Column="2"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#FFCC66"
                           MinWidth="40" TextAlignment="Right"
                           Text="100%"/>
            </Grid>

            <!-- ── Wanted-affix checkbox list ─────────────────────────────────────────── -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Wanted affixes"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Tick each affix you want the hunt to count.  Patterns match against the affix's internal path -- if you don't see a stat you want, the affix may use a different name on your server.  Add it via Settings later."/>

            <ItemsControl x:Name="PatternList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding CategoryLabel}"
                                       Style="{StaticResource CategoryHeader}"/>
                            <ItemsControl ItemsSource="{Binding Patterns}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Style="{StaticResource AffixCheck}"
                                                  Content="{Binding Label}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  ToolTip="{Binding Description}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Status line ────────────────────────────────────────────────────────── -->
            <Border Margin="0,16,0,0" Padding="10,8"
                    Background="#0F0F0F"
                    BorderBrush="#44FFFFFF" BorderThickness="1"
                    CornerRadius="3">
                <TextBlock x:Name="StatusLine"
                           Foreground="#AAFFFFFF" FontSize="11"
                           TextWrapping="Wrap"
                           Text="loading..."/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
