<UserControl x:Class="MarvelHeroes.DpsMeter.Controls.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A"
             Foreground="#CCFFFFFF">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFCC66"/>
            <Setter Property="Margin" Value="0,18,0,6"/>
        </Style>
        <Style x:Key="SectionHeaderFirst" TargetType="TextBlock" BasedOn="{StaticResource SectionHeader}">
            <!-- First section gets less top margin so it doesn't float far from the top edge -->
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="SettingCheckbox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDFFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#77FFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="22,0,0,2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SettingsButton}">
            <!-- Subtle red tint for destructive actions so they don't blend into the rest -->
            <Setter Property="BorderBrush" Value="#88D62A2A"/>
            <Setter Property="Foreground" Value="#FFCCAAAA"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="24,18,24,18">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">

            <!-- ── Display ─────────────────────────────────────────────────────────────── -->
            <TextBlock Text="DISPLAY" Style="{StaticResource SectionHeaderFirst}"/>

            <CheckBox x:Name="BossOnlyCheckbox" Style="{StaticResource SettingCheckbox}"
                      Content="Boss DPS only (main section)"
                      Checked="BossOnlyCheckbox_OnChecked"
                      Unchecked="BossOnlyCheckbox_OnUnchecked"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Restricts the headline DPS / leaderboard to damage dealt to boss and group-boss targets only.  Mini-bosses are intentionally excluded."/>

            <CheckBox x:Name="ShowBossSectionCheckbox" Style="{StaticResource SettingCheckbox}"
                      Content="Show separate Boss Fight section"
                      Checked="ShowBossSectionCheckbox_OnChecked"
                      Unchecked="ShowBossSectionCheckbox_OnUnchecked"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Adds a second leaderboard below the main one that always tracks boss-only encounter damage, regardless of the toggle above."/>

            <CheckBox x:Name="ShowPowerBreakdownCheckbox" Style="{StaticResource SettingCheckbox}"
                      Content="Show my power breakdown"
                      Checked="ShowPowerBreakdownCheckbox_OnChecked"
                      Unchecked="ShowPowerBreakdownCheckbox_OnUnchecked"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Adds a per-ability breakdown of your own damage with hit counts and damage shares."/>

            <CheckBox x:Name="ShowSplinterCheckbox" Style="{StaticResource SettingCheckbox}"
                      Content="Show Eternity Splinter tracker"
                      Checked="ShowSplinterCheckbox_OnChecked"
                      Unchecked="ShowSplinterCheckbox_OnUnchecked"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Shows a small status pill with the 7-minute server-side cooldown between Eternity Splinter drops."/>

            <CheckBox x:Name="SplinterSoundCheckbox" Style="{StaticResource SettingCheckbox}"
                      Content="Play sound when Splinter cooldown ends"
                      Checked="SplinterSoundCheckbox_OnChecked"
                      Unchecked="SplinterSoundCheckbox_OnUnchecked"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Routes through Windows' notification-sound channel, so the OS-level volume / mute setting applies."/>

            <!-- ── Overlay scale ───────────────────────────────────────────────────────── -->
            <TextBlock Text="OVERLAY SCALE" Style="{StaticResource SectionHeader}"/>
            <TextBlock Style="{StaticResource HintText}" Margin="0,0,0,4"
                       Text="Resizes the overlay (and main Live tab content) between 25% and 200%."/>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="ScaleSlider" Grid.Column="0"
                        Minimum="0.25" Maximum="2.0" SmallChange="0.05" LargeChange="0.25"
                        TickFrequency="0.25" TickPlacement="BottomRight" IsSnapToTickEnabled="False"
                        ValueChanged="ScaleSlider_ValueChanged"/>
                <TextBlock x:Name="ScaleReadout" Grid.Column="1"
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#FFCC66"
                           MinWidth="48" TextAlignment="Right"
                           Text="100%"/>
            </Grid>

            <!-- ── Actions ──────────────────────────────────────────────────────────────── -->
            <TextBlock Text="ACTIONS" Style="{StaticResource SectionHeader}"/>
            <WrapPanel>
                <Button Content="Clear DPS (session)" Style="{StaticResource SettingsButton}"
                        Click="ClearDpsButton_Click"/>
                <Button Content="Reset hero max-hit record…" Style="{StaticResource DangerButton}"
                        Click="ResetMaxHitButton_Click"/>
                <Button Content="Reset Splinter cooldown" Style="{StaticResource SettingsButton}"
                        Click="ResetSplinterButton_Click"/>
                <Button Content="Test Splinter sound" Style="{StaticResource SettingsButton}"
                        Click="TestSoundButton_Click"/>
            </WrapPanel>

            <!-- ── Diagnostics ─────────────────────────────────────────────────────────── -->
            <TextBlock Text="DIAGNOSTICS" Style="{StaticResource SectionHeader}"/>

            <CheckBox x:Name="LoggingCheckbox" Style="{StaticResource SettingCheckbox}"
                      Content="Write diagnostic log to disk"
                      Checked="LoggingCheckbox_OnChecked"
                      Unchecked="LoggingCheckbox_OnUnchecked"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Captures per-event triage info (encounter lifecycle, peer-pet folds, hero-resolution failures, loot-drop discovery, etc.).  ~1–5 MB / hour during active play.  Toggle off when you're not debugging."/>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LogPathText" Grid.Column="0"
                           FontFamily="Consolas" FontSize="10" Foreground="#88FFFFFF"
                           VerticalAlignment="Center" TextWrapping="Wrap"
                           Text="(log path)"/>
                <Button Grid.Column="1" Content="Open log folder"
                        Style="{StaticResource SettingsButton}" Margin="14,0,0,0"
                        Click="OpenLogFolderButton_Click"/>
            </Grid>

            <!-- ── About ───────────────────────────────────────────────────────────────── -->
            <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}"/>
            <TextBlock x:Name="AboutText"
                       FontFamily="Segoe UI" FontSize="11" Foreground="#AAFFFFFF"
                       TextWrapping="Wrap"
                       Text="Marvel Heroes DPS Meter"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
