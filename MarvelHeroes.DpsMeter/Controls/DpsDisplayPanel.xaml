<UserControl x:Class="MarvelHeroes.DpsMeter.Controls.DpsDisplayPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <FontFamily x:Key="MarvelFontSecondary">Segoe UI Semibold</FontFamily>
    </UserControl.Resources>

    <Border x:Name="ContentBorder"
            Padding="20,12"
            Background="#B2000000"
            CornerRadius="10"
            BorderBrush="#66FF6B00"
            BorderThickness="1"
            MouseLeftButtonDown="ContentBorder_MouseLeftButtonDown">
        <Border.ContextMenu>
            <ContextMenu x:Name="OverlayMenu">
                <MenuItem x:Name="BossOnlyMenuItem"
                          Header="Boss DPS only (main section)"
                          IsCheckable="True"
                          Checked="BossOnlyMenuItem_OnChecked"
                          Unchecked="BossOnlyMenuItem_OnUnchecked"/>
                <MenuItem x:Name="ShowBossSectionMenuItem"
                          Header="Show boss fight section"
                          IsCheckable="True"
                          Checked="ShowBossSectionMenuItem_OnChecked"
                          Unchecked="ShowBossSectionMenuItem_OnUnchecked"/>
                <MenuItem x:Name="ShowPowerBreakdownMenuItem"
                          Header="Show my power breakdown"
                          IsCheckable="True"
                          Checked="ShowPowerBreakdownMenuItem_OnChecked"
                          Unchecked="ShowPowerBreakdownMenuItem_OnUnchecked"/>
                <MenuItem Header="Scale">
                    <MenuItem x:Name="Scale25MenuItem"  Header="25%"  IsCheckable="True" Click="ScaleMenuItem_Click" Tag="0.25"/>
                    <MenuItem x:Name="Scale50MenuItem"  Header="50%"  IsCheckable="True" Click="ScaleMenuItem_Click" Tag="0.5"/>
                    <MenuItem x:Name="Scale75MenuItem"  Header="75%"  IsCheckable="True" Click="ScaleMenuItem_Click" Tag="0.75"/>
                    <MenuItem x:Name="Scale100MenuItem" Header="100%" IsCheckable="True" Click="ScaleMenuItem_Click" Tag="1"/>
                    <MenuItem x:Name="Scale125MenuItem" Header="125%" IsCheckable="True" Click="ScaleMenuItem_Click" Tag="1.25"/>
                    <MenuItem x:Name="Scale150MenuItem" Header="150%" IsCheckable="True" Click="ScaleMenuItem_Click" Tag="1.5"/>
                    <MenuItem x:Name="Scale175MenuItem" Header="175%" IsCheckable="True" Click="ScaleMenuItem_Click" Tag="1.75"/>
                    <MenuItem x:Name="Scale200MenuItem" Header="200%" IsCheckable="True" Click="ScaleMenuItem_Click" Tag="2"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Save snapshot" Click="SaveSnapshotMenuItem_OnClick"/>
                <MenuItem Header="Clear DPS"     Click="ClearDpsMenuItem_OnClick"/>
                <MenuItem Header="View reports"  Click="ViewReportsMenuItem_OnClick"/>
                <Separator/>
                <MenuItem x:Name="SwitchModeMenuItem" Header="Switch to window mode" Click="SwitchModeMenuItem_OnClick"/>
                <Separator/>
                <MenuItem Header="Exit" Click="ExitMenuItem_OnClick"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#FF000000" Opacity="0.85"/>
        </Border.Effect>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">

            <!-- ── Main section ──────────────────────────────────────────── -->
            <Grid Width="280" Margin="0,0,0,2" HorizontalAlignment="Left">
                <TextBlock x:Name="HeroTitleText"
                           Text="DPS"
                           FontFamily="{StaticResource MarvelFontSecondary}"
                           FontSize="14"
                           Foreground="#99FFFFFF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="CloseButton"
                           Text="×"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="#55FFFFFF"
                           Cursor="Hand"
                           Visibility="Collapsed"
                           MouseLeftButtonDown="CloseButton_OnClick">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#CCFFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <TextBlock x:Name="DpsText"
                       Text="—"
                       FontFamily="{StaticResource MarvelFontSecondary}"
                       FontSize="38"
                       FontWeight="Bold"
                       Foreground="#FFFFB347"
                       HorizontalAlignment="Center"
                       LineHeight="40"
                       LineStackingStrategy="BlockLineHeight">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#FF000000" Opacity="0.9"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="MaxHitText"
                       Text=""
                       FontFamily="{StaticResource MarvelFontSecondary}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#FFFFE0A8"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
            <TextBlock x:Name="DetailText"
                       Text=""
                       FontFamily="{StaticResource MarvelFontSecondary}"
                       FontSize="11"
                       Foreground="#80FFFFFF"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,0"/>

            <Border Margin="0,8,0,4" BorderBrush="#33FF6B00" BorderThickness="0,0,0,1"/>

            <!-- Row template: [portrait | name | DPS | total | %] on a 280px bar track -->
            <Grid Width="280" Height="28" Margin="0,4,0,0" HorizontalAlignment="Left">
                <Rectangle x:Name="Top1Bar" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" Fill="#66FF6B00"/>
                <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="50"/>
                        <ColumnDefinition Width="Auto" MinWidth="46"/>
                        <ColumnDefinition Width="Auto" MinWidth="38"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="Top1Image" Grid.Column="0" Width="28" Height="28" Stretch="UniformToFill" SnapsToDevicePixels="True" Margin="0,0,8,0"/>
                    <TextBlock x:Name="Top1Text"  Grid.Column="1" Text="" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                    <TextBlock x:Name="Top1Dps"   Grid.Column="2" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                    <TextBlock x:Name="Top1Total" Grid.Column="3" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                    <TextBlock x:Name="Top1Pct"   Grid.Column="4" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                </Grid>
            </Grid>
            <Grid Width="280" Height="28" Margin="0,3,0,0" HorizontalAlignment="Left">
                <Rectangle x:Name="Top2Bar" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" Fill="#66FF6B00"/>
                <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="50"/>
                        <ColumnDefinition Width="Auto" MinWidth="46"/>
                        <ColumnDefinition Width="Auto" MinWidth="38"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="Top2Image" Grid.Column="0" Width="28" Height="28" Stretch="UniformToFill" SnapsToDevicePixels="True" Margin="0,0,8,0"/>
                    <TextBlock x:Name="Top2Text"  Grid.Column="1" Text="" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                    <TextBlock x:Name="Top2Dps"   Grid.Column="2" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                    <TextBlock x:Name="Top2Total" Grid.Column="3" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                    <TextBlock x:Name="Top2Pct"   Grid.Column="4" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                </Grid>
            </Grid>
            <Grid Width="280" Height="28" Margin="0,3,0,0" HorizontalAlignment="Left">
                <Rectangle x:Name="Top3Bar" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" Fill="#66FF6B00"/>
                <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="50"/>
                        <ColumnDefinition Width="Auto" MinWidth="46"/>
                        <ColumnDefinition Width="Auto" MinWidth="38"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="Top3Image" Grid.Column="0" Width="28" Height="28" Stretch="UniformToFill" SnapsToDevicePixels="True" Margin="0,0,8,0"/>
                    <TextBlock x:Name="Top3Text"  Grid.Column="1" Text="" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                    <TextBlock x:Name="Top3Dps"   Grid.Column="2" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                    <TextBlock x:Name="Top3Total" Grid.Column="3" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                    <TextBlock x:Name="Top3Pct"   Grid.Column="4" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                </Grid>
            </Grid>
            <Grid Width="280" Height="28" Margin="0,3,0,0" HorizontalAlignment="Left">
                <Rectangle x:Name="Top4Bar" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" Fill="#66FF6B00"/>
                <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="50"/>
                        <ColumnDefinition Width="Auto" MinWidth="46"/>
                        <ColumnDefinition Width="Auto" MinWidth="38"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="Top4Image" Grid.Column="0" Width="28" Height="28" Stretch="UniformToFill" SnapsToDevicePixels="True" Margin="0,0,8,0"/>
                    <TextBlock x:Name="Top4Text"  Grid.Column="1" Text="" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                    <TextBlock x:Name="Top4Dps"   Grid.Column="2" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                    <TextBlock x:Name="Top4Total" Grid.Column="3" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                    <TextBlock x:Name="Top4Pct"   Grid.Column="4" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                </Grid>
            </Grid>
            <Grid Width="280" Height="28" Margin="0,3,0,0" HorizontalAlignment="Left">
                <Rectangle x:Name="Top5Bar" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" Fill="#66FF6B00"/>
                <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="50"/>
                        <ColumnDefinition Width="Auto" MinWidth="46"/>
                        <ColumnDefinition Width="Auto" MinWidth="38"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="Top5Image" Grid.Column="0" Width="28" Height="28" Stretch="UniformToFill" SnapsToDevicePixels="True" Margin="0,0,8,0"/>
                    <TextBlock x:Name="Top5Text"  Grid.Column="1" Text="" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                    <TextBlock x:Name="Top5Dps"   Grid.Column="2" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                    <TextBlock x:Name="Top5Total" Grid.Column="3" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                    <TextBlock x:Name="Top5Pct"   Grid.Column="4" Text="" TextAlignment="Right"            HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                </Grid>
            </Grid>

            <!-- ── Boss fight section (toggle via right-click menu) ──────── -->
            <StackPanel x:Name="BossFightPanel" Visibility="Collapsed">
                <Grid Width="280" Margin="0,10,0,4" HorizontalAlignment="Left">
                    <Rectangle Height="1" VerticalAlignment="Center" Fill="#44FF6B00"/>
                    <Border HorizontalAlignment="Center" Background="#B2000000" Padding="8,0">
                        <TextBlock Text="BOSS FIGHT" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="10" Foreground="#BBFF6B00"/>
                    </Border>
                </Grid>
                <TextBlock x:Name="BossDpsText" Text="—" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="28" FontWeight="Bold" Foreground="#FFFFB347" HorizontalAlignment="Center">
                    <TextBlock.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#FF000000" Opacity="0.9"/></TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="BossDetailText" Text="" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="11" Foreground="#80FFFFFF" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                <Border Margin="0,6,0,4" BorderBrush="#33FF6B00" BorderThickness="0,0,0,1"/>
                <Grid Width="280" Height="28" Margin="0,4,0,0" HorizontalAlignment="Left">
                    <Rectangle x:Name="Boss1Bar" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" Fill="#66FF6B00"/>
                    <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto" MinWidth="50"/><ColumnDefinition Width="Auto" MinWidth="46"/><ColumnDefinition Width="Auto" MinWidth="38"/></Grid.ColumnDefinitions>
                        <Image x:Name="Boss1Image" Grid.Column="0" Width="28" Height="28" Stretch="UniformToFill" SnapsToDevicePixels="True" Margin="0,0,8,0"/>
                        <TextBlock x:Name="Boss1Text"  Grid.Column="1" Text="" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                        <TextBlock x:Name="Boss1Dps"   Grid.Column="2" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                        <TextBlock x:Name="Boss1Total" Grid.Column="3" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                        <TextBlock x:Name="Boss1Pct"   Grid.Column="4" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                    </Grid>
                </Grid>
                <Grid Width="280" Height="28" Margin="0,3,0,0" HorizontalAlignment="Left">
                    <Rectangle x:Name="Boss2Bar" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" Fill="#66FF6B00"/>
                    <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto" MinWidth="50"/><ColumnDefinition Width="Auto" MinWidth="46"/><ColumnDefinition Width="Auto" MinWidth="38"/></Grid.ColumnDefinitions>
                        <Image x:Name="Boss2Image" Grid.Column="0" Width="28" Height="28" Stretch="UniformToFill" SnapsToDevicePixels="True" Margin="0,0,8,0"/>
                        <TextBlock x:Name="Boss2Text"  Grid.Column="1" Text="" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                        <TextBlock x:Name="Boss2Dps"   Grid.Column="2" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                        <TextBlock x:Name="Boss2Total" Grid.Column="3" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                        <TextBlock x:Name="Boss2Pct"   Grid.Column="4" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                    </Grid>
                </Grid>
                <Grid Width="280" Height="28" Margin="0,3,0,0" HorizontalAlignment="Left">
                    <Rectangle x:Name="Boss3Bar" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" Fill="#66FF6B00"/>
                    <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto" MinWidth="50"/><ColumnDefinition Width="Auto" MinWidth="46"/><ColumnDefinition Width="Auto" MinWidth="38"/></Grid.ColumnDefinitions>
                        <Image x:Name="Boss3Image" Grid.Column="0" Width="28" Height="28" Stretch="UniformToFill" SnapsToDevicePixels="True" Margin="0,0,8,0"/>
                        <TextBlock x:Name="Boss3Text"  Grid.Column="1" Text="" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                        <TextBlock x:Name="Boss3Dps"   Grid.Column="2" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                        <TextBlock x:Name="Boss3Total" Grid.Column="3" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                        <TextBlock x:Name="Boss3Pct"   Grid.Column="4" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                    </Grid>
                </Grid>
                <Grid Width="280" Height="28" Margin="0,3,0,0" HorizontalAlignment="Left">
                    <Rectangle x:Name="Boss4Bar" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" Fill="#66FF6B00"/>
                    <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto" MinWidth="50"/><ColumnDefinition Width="Auto" MinWidth="46"/><ColumnDefinition Width="Auto" MinWidth="38"/></Grid.ColumnDefinitions>
                        <Image x:Name="Boss4Image" Grid.Column="0" Width="28" Height="28" Stretch="UniformToFill" SnapsToDevicePixels="True" Margin="0,0,8,0"/>
                        <TextBlock x:Name="Boss4Text"  Grid.Column="1" Text="" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                        <TextBlock x:Name="Boss4Dps"   Grid.Column="2" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                        <TextBlock x:Name="Boss4Total" Grid.Column="3" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                        <TextBlock x:Name="Boss4Pct"   Grid.Column="4" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                    </Grid>
                </Grid>
                <Grid Width="280" Height="28" Margin="0,3,0,0" HorizontalAlignment="Left">
                    <Rectangle x:Name="Boss5Bar" HorizontalAlignment="Left" Width="0" RadiusX="3" RadiusY="3" Fill="#66FF6B00"/>
                    <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto" MinWidth="50"/><ColumnDefinition Width="Auto" MinWidth="46"/><ColumnDefinition Width="Auto" MinWidth="38"/></Grid.ColumnDefinitions>
                        <Image x:Name="Boss5Image" Grid.Column="0" Width="28" Height="28" Stretch="UniformToFill" SnapsToDevicePixels="True" Margin="0,0,8,0"/>
                        <TextBlock x:Name="Boss5Text"  Grid.Column="1" Text="" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                        <TextBlock x:Name="Boss5Dps"   Grid.Column="2" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                        <TextBlock x:Name="Boss5Total" Grid.Column="3" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#99FFFFFF"/>
                        <TextBlock x:Name="Boss5Pct"   Grid.Column="4" Text="" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="13" Foreground="#CCFFFFFF"/>
                    </Grid>
                </Grid>
            </StackPanel>

            <!-- ── Power breakdown section ─────────────────────────────── -->
            <StackPanel x:Name="PowerBreakdownPanel" Visibility="Collapsed">
                <Grid Width="280" Margin="0,10,0,4" HorizontalAlignment="Left">
                    <Rectangle Height="1" VerticalAlignment="Center" Fill="#44FF6B00"/>
                    <Border HorizontalAlignment="Center" Background="#B2000000" Padding="8,0">
                        <TextBlock Text="MY POWERS" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="10" Foreground="#BBFF6B00"/>
                    </Border>
                </Grid>
                <Canvas x:Name="PwrSegCanvas" Width="280" Height="8" Margin="0,0,0,4" HorizontalAlignment="Left" ClipToBounds="True">
                    <Rectangle x:Name="PwrSeg1" Canvas.Top="0" Canvas.Left="0" Width="0" Height="8" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="PwrSeg2" Canvas.Top="0" Canvas.Left="0" Width="0" Height="8" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="PwrSeg3" Canvas.Top="0" Canvas.Left="0" Width="0" Height="8" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="PwrSeg4" Canvas.Top="0" Canvas.Left="0" Width="0" Height="8" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="PwrSeg5" Canvas.Top="0" Canvas.Left="0" Width="0" Height="8" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="PwrSeg6" Canvas.Top="0" Canvas.Left="0" Width="0" Height="8" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="PwrSeg7" Canvas.Top="0" Canvas.Left="0" Width="0" Height="8" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="PwrSeg8" Canvas.Top="0" Canvas.Left="0" Width="0" Height="8" RadiusX="2" RadiusY="2"/>
                </Canvas>
                <Grid Width="280" Height="22" Margin="0,2,0,0" HorizontalAlignment="Left">
                    <Rectangle x:Name="Pwr1Bar" HorizontalAlignment="Left" Width="0" Height="22" RadiusX="3" RadiusY="3"/>
                    <Grid VerticalAlignment="Center" Margin="4,0,4,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/><ColumnDefinition Width="50"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                        <TextBlock x:Name="Pwr1Name"  Grid.Column="0" Text="" TextTrimming="CharacterEllipsis" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
                        <TextBlock x:Name="Pwr1Hits"  Grid.Column="1" Text="" TextAlignment="Right" HorizontalAlignment="Right" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="11" Foreground="#88FFFFFF" VerticalAlignment="Center"/>
                        <TextBlock x:Name="Pwr1Total" Grid.Column="2" Text="" TextAlignment="Right" HorizontalAlignment="Right" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="11" Foreground="#88FFFFFF" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="Pwr1Pct"   Grid.Column="3" Text="" TextAlignment="Right" HorizontalAlignment="Right" FontFamily="{StaticResource MarvelFontSecondary}" FontSize="12" Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
                <Grid Width="280" Height="22" Margin="0,2,0,0" HorizontalAlignment="Left">
