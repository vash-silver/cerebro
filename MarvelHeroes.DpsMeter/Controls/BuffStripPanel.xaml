<UserControl x:Class="MarvelHeroes.DpsMeter.Controls.BuffStripPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <!--
        Two-tier buff strip rendered above the leaderboard.

        Row 0 (PlayerFacing chips): larger font, more prominent border, full opacity.
            Represents ability-applied timed buffs (Empowered, Tumble, Heal Medium Power, etc).
            These are the buffs that drive rotation decisions.

        Row 1 (ItemProc chips): smaller, slightly muted, narrower padding.
            Represents gear-fired procs (Art159 Stacking Power, Unique163 Crit Proc, etc).
            Shown so the player can see their gear is firing without dominating the view.

        Both rows are virtualizing-disabled because the chip counts are tiny (typically
        5-15 each at peak), so the perf cost of a fresh layout per tick is negligible and
        we get simpler code without the ItemsControl virtualization gotchas.

        The chip ItemsSource is rebuilt every decay tick (~4 Hz) by the code-behind.
        Cheap enough at these sizes, and avoids the complexity of INotifyPropertyChanged
        countdowns.
    -->
    <StackPanel Orientation="Vertical" Margin="0,0,0,6">

        <!-- Row 0: player-facing buffs -->
        <ItemsControl x:Name="PlayerFacingRow"
                      Visibility="Collapsed"
                      Margin="0,0,0,4">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1A2E7FFF" BorderBrush="#552E7FFF" BorderThickness="1"
                            CornerRadius="3" Padding="8,4" Margin="0,0,6,4"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ShortName}"
                                       FontFamily="Segoe UI Semibold" FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FFCCDDFF"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StackSuffix}"
                                       FontFamily="Segoe UI Semibold" FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#FFFFCC66"
                                       Margin="4,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding StackVisibility}"/>
                            <TextBlock Text="{Binding RemainingText}"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#88FFFFFF"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Row 1: item / gear procs -->
        <ItemsControl x:Name="ItemProcRow"
                      Visibility="Collapsed">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#15FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1"
                            CornerRadius="2" Padding="6,2" Margin="0,0,4,3"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ShortName}"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#AAFFFFFF"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StackSuffix}"
                                       FontFamily="Segoe UI" FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#FFCC66"
                                       Margin="3,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding StackVisibility}"/>
                            <TextBlock Text="{Binding RemainingText}"
                                       FontFamily="Consolas" FontSize="9"
                                       Foreground="#66FFFFFF"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</UserControl>
