<Window x:Class="MarvelHeroes.DpsMeter.BuffOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MarvelHeroes.DpsMeter.Controls"
        Title="Buffs"
        MinWidth="120"
        MinHeight="60"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        WindowStartupLocation="Manual">
    <!--
        Two render modes inside the same window:
          * Strip mode  (default).  BuffStripPanel inside a styled card border.  Chips
                                    auto-flow horizontally; tightly-spaced status pill.
          * Free-layout mode.       FreeLayoutBuffPanel inside a transparent backdrop.
                                    Each tracked buff is a bare icon at a user-set
                                    (X, Y) on the canvas; WeakAuras-style HUD.
        Mode swap is driven by TrackedBuffsConfig.Current.FreeLayoutMode, polled by the
        code-behind on every UpdateBuffs call (cheap; single field read).
    -->
    <Grid>
        <!-- Strip-mode container.  Visible when FreeLayoutMode == false. -->
        <Border x:Name="StripFrame"
                Padding="8,6"
                Background="#99000000"
                CornerRadius="8"
                BorderBrush="#552E7FFF"
                BorderThickness="1"
                MouseLeftButtonDown="Frame_MouseLeftButtonDown">
            <controls:BuffStripPanel x:Name="Strip"/>
        </Border>
        <!-- Free-layout container.  Visible when FreeLayoutMode == true.  No background
             chrome, icons float on the game.  Mouse events on the canvas itself drag
             the window (matches strip mode), but chip-level events handle their own
             drag in edit mode (mouse capture wins over the canvas-level handler). -->
        <Grid x:Name="FreeLayoutFrame"
              Visibility="Collapsed"
              Background="Transparent"
              MouseLeftButtonDown="Frame_MouseLeftButtonDown">
            <controls:FreeLayoutBuffPanel x:Name="FreeLayout"/>
        </Grid>
    </Grid>
</Window>
