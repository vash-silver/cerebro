<Window x:Class="MarvelHeroes.DpsMeter.Windows.HotkeyCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rebind hotkey"
        Width="420" Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        Background="#1A1A1A"
        Foreground="#CCFFFFFF"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Press a key combination"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="#FFCC66"/>
            <TextBlock Text="Include at least one of Ctrl / Alt / Shift / Win, plus a regular key.  Esc cancels."
                       FontSize="11" Foreground="#88FFFFFF"
                       TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,16,0,16"
                Background="#111111" BorderBrush="#552E7FFF" BorderThickness="1"
                CornerRadius="4">
            <TextBlock x:Name="DisplayText"
                       FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                       Foreground="#FFCC66"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Text="(waiting…)"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Margin="0,0,8,0"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
            <Button x:Name="AcceptButton" Content="Use this" Width="80"
                    Click="AcceptButton_Click"
                    IsDefault="True" IsEnabled="False"
                    Background="#222"
                    Foreground="#FFCC66"/>
        </StackPanel>
    </Grid>
</Window>
