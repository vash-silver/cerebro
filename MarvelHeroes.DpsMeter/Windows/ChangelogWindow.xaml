<Window x:Class="MarvelHeroes.DpsMeter.Windows.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cerebro changelog"
        Width="780" Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        Background="#1A1A1A"
        Foreground="#CCFFFFFF"
        FontFamily="Segoe UI">
    <!--
        Bundled CHANGELOG.md viewer.  Reads the markdown text from the embedded
        WPF resource (pack://application:,,,/CHANGELOG.md) at construction time
        and dumps it into a read-only TextBox.  Intentionally not Markdown
        rendered (the source is meant to be readable as plain text, and shipping
        a markdown renderer would bloat the EXE for one feature).
    -->
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="Cerebro changelog"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="#FFCC66"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="VersionSubtitle"
                       Margin="10,0,0,0"
                       FontSize="11"
                       Foreground="#88FFFFFF"
                       VerticalAlignment="Center"
                       Text="(running v?)"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,10,0,10"
                Background="#0F0F0F" BorderBrush="#44FFFFFF" BorderThickness="1"
                CornerRadius="3">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="2">
                <TextBox x:Name="ChangelogText"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="#DDFFFFFF"
                         FontFamily="Consolas" FontSize="12"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled"
                         CaretBrush="Transparent"
                         SelectionBrush="#552E7FFF"
                         Padding="14,12"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Open on GitHub" Width="130" Margin="0,0,8,0"
                    Padding="0,5"
                    Click="OpenOnGithubButton_Click"
                    Background="#222"
                    Foreground="#DDFFFFFF"
                    BorderBrush="#44FFFFFF"
                    Cursor="Hand"
                    ToolTip="Opens the latest CHANGELOG.md on the Cerebro GitHub repo in your default browser"/>
            <Button Content="Close" Width="80"
                    Padding="0,5"
                    Click="CloseButton_Click"
                    IsCancel="True"
                    IsDefault="True"
                    Background="#222"
                    Foreground="#FFCC66"
                    BorderBrush="#44FFFFFF"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
