<Window x:Class="MarvelHeroes.DpsMeter.Windows.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MarvelHeroes.DpsMeter.Controls"
        Title="Cerebro"
        Width="900" Height="640"
        MinWidth="640" MinHeight="480"
        Background="#1A1A1A"
        Foreground="#CCFFFFFF"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!--
            Tab strip styling.  WPF's default TabItem renders a Windows-ish bevelled tab on a
            light-grey strip that fights the dark theme; this template draws a flat orange
            underline on the active tab and a subdued label on inactive ones, matching the
            rest of the app.
        -->
        <Style x:Key="DarkTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF6B00"/>
                                <Setter Property="Foreground"               Value="#FFCC66"/>
                                <Setter Property="FontWeight"               Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#DDFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkTab" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkTabItem}"/>
        </Style>
        <Style x:Key="HeaderCheckbox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header strip -->
            <RowDefinition Height="Auto"/>  <!-- update banner (collapsed by default) -->
            <RowDefinition Height="*"/>     <!-- main content -->
            <RowDefinition Height="Auto"/>  <!-- footer status strip -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#0F0F0F" BorderBrush="#33FFFFFF"
                BorderThickness="0,0,0,1" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Cerebro"
                               FontFamily="Segoe UI Semibold" FontSize="14"
                               Foreground="#FFCC66"/>
                    <TextBlock Text="DPS Meter"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#88FFFFFF"
                               VerticalAlignment="Center"
                               Margin="8,2,0,0"/>
                    <TextBlock x:Name="StatusBadge"
                               Margin="14,0,0,0"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#77FFFFFF"
                               VerticalAlignment="Center"
                               Text="initializing…"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox x:Name="ShowOverlayCheckbox"
                              Style="{StaticResource HeaderCheckbox}"
                              Content="Show overlay"
                              ToolTip="Toggle the floating always-on-top overlay window that mirrors the Live tab"
                              Checked="ShowOverlayCheckbox_OnChecked"
                              Unchecked="ShowOverlayCheckbox_OnUnchecked"/>
                    <CheckBox x:Name="PersistOverlayCheckbox"
                              Style="{StaticResource HeaderCheckbox}"
                              Content="Persist overlay"
                              Margin="0,4,0,0"
                              ToolTip="Will keep overlay active when you alt tab. Turn off if you're a single monitor user."
                              Checked="PersistOverlayCheckbox_OnChanged"
                              Unchecked="PersistOverlayCheckbox_OnChanged"/>
                    <CheckBox x:Name="ShowBuffOverlayCheckbox"
                              Style="{StaticResource HeaderCheckbox}"
                              Content="Show buff overlay"
                              Margin="0,4,0,0"
                              ToolTip="Floating window that shows your tracked buffs over the game.  Configure the watchlist in the Buff Tracker tab."
                              Checked="ShowBuffOverlayCheckbox_OnChanged"
                              Unchecked="ShowBuffOverlayCheckbox_OnChanged"/>
                    <CheckBox x:Name="ShowCooldownOverlayCheckbox"
                              Style="{StaticResource HeaderCheckbox}"
                              Content="Show cooldown overlay"
                              Margin="0,4,0,0"
                              ToolTip="Floating WeakAuras-style icons for tracked power cooldowns.  Configure in the Cooldown Tracker tab."
                              Checked="ShowCooldownOverlayCheckbox_OnChanged"
                              Unchecked="ShowCooldownOverlayCheckbox_OnChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Tabs ──────────────────────────────────────────────────────────────── -->
        <!--
            Update-available banner.  Collapsed by default; toggled visible by the
            background update checker when a newer GitHub release is detected and the
            user hasn't dismissed it (the dismiss state is stored as the tag name in
            DpsOverlaySettingsFile.DismissedUpdateVersion so the banner re-appears only
            for genuinely-newer releases).
        -->
        <Border Grid.Row="1" x:Name="UpdateBanner" Visibility="Collapsed"
                Background="#332E7FFF" BorderBrush="#882E7FFF" BorderThickness="0,0,0,1"
                Padding="14,6">
            <StackPanel Orientation="Vertical">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="UpdateBannerText" Grid.Column="0"
                               Foreground="#FFCC99FF" FontSize="12"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Text="Update available"/>
                    <!-- Primary action: in-place self-update.  Downloads + verifies +
                         extracts the new zip, then relaunches Cerebro via a tiny
                         PowerShell bootstrap (the only way to replace a running EXE
                         on Windows). -->
                    <Button x:Name="UpdateBannerInstallButton"
                            Grid.Column="1" Content="Update now"
                            Margin="0,0,6,0" Padding="14,3" Cursor="Hand"
                            Background="#552E7FFF" BorderBrush="#AA2E7FFF" BorderThickness="1"
                            Foreground="#FFFFFFFF"
                            ToolTip="Download + install the latest version, then restart Cerebro"
                            Click="UpdateBannerInstall_Click"/>
                    <!-- Fallback: open the release page in a browser.  Hidden during
                         normal flow; we surface it only on install failure so the
                         user always has a manual path. -->
                    <Button x:Name="UpdateBannerOpenPageButton"
                            Grid.Column="2" Content="Open release page"
                            Margin="0,0,6,0" Padding="10,3" Cursor="Hand"
                            Background="Transparent" BorderBrush="#552E7FFF" BorderThickness="1"
                            Foreground="#DDFFFFFF" FontSize="11"
                            Visibility="Collapsed"
                            Click="UpdateBannerOpenPage_Click"/>
                    <Button x:Name="UpdateBannerDismissButton"
                            Grid.Column="3" Content="✕"
                            Padding="8,3" Cursor="Hand"
                            Background="Transparent" BorderBrush="#552E7FFF" BorderThickness="1"
                            Foreground="#DDFFFFFF"
                            ToolTip="Dismiss until a newer release is published"
                            Click="UpdateBannerDismiss_Click"/>
                </Grid>
                <!-- Progress bar lives on a second row so it can span the full width
                     of the banner without fighting the buttons for space.  Hidden
                     except during an active install. -->
                <ProgressBar x:Name="UpdateBannerProgress"
                             Visibility="Collapsed"
                             Margin="0,6,0,0"
                             Height="6"
                             Minimum="0" Maximum="100"
                             Background="#22000000"
                             Foreground="#FF2E7FFF"
                             BorderThickness="0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="2" x:Name="MainTabs" Style="{StaticResource DarkTab}">
            <TabItem Header="Live">
                <Border Background="#1A1A1A" Padding="0">
                    <!--
                        The Live tab hosts the same DpsDisplayPanel UserControl the overlay
                        uses, so all the existing rendering / menu / settings persistence
                        wiring works unchanged.  The panel sits centred at the top of the
                        tab so its 280-px-wide leaderboard layout looks deliberate inside a
                        wider window.
                    -->
                    <!--
                        Dashboard layout purpose-built for the main app's wider canvas
                        (compared to the 280-px-wide DpsDisplayPanel the overlay still uses).
                        Summary card at top, leaderboard + power-breakdown side by side, boss
                        banner at the bottom when an encounter's active.
                    -->
                    <controls:LiveDashboardPanel x:Name="LivePanel"/>
                </Border>
            </TabItem>
            <TabItem Header="Reports">
                <!--
                    Embedded ReportViewerPanel with the Close button hidden. Closing a tab
                    isn't a concept, and Copy / Delete are still useful inside the tab.
                -->
                <controls:ReportViewerPanel x:Name="ReportsPanel"
                                            ShowCloseButton="False"
                                            Margin="8"/>
            </TabItem>
            <TabItem Header="Settings">
                <!--
                    Settings tab consolidates the right-click-menu toggles + actions into a
                    proper surface.  Backed by the same DpsOverlaySettingsFile singleton the
                    panels share.  The right-click menu still works on the overlay for when
                    the main window isn't in front.
                -->
                <controls:SettingsPanel x:Name="SettingsTab"/>
            </TabItem>
            <TabItem Header="Cosmic Loot Scanner">
                <!--
                    Cosmic Loot Scanner tab.  Configures the hunt-mode filter (which affixes count,
                    minimum hits, rarity gate, self-equippable gate).  Saves instantly to
                    %LocalAppData%\MarvelHeroesComporator\loot-hunt-config.json; the live
                    LootScannerDiagnostic re-reads on every drop so changes take effect
                    without a restart.
                -->
                <controls:LootScannerPanel x:Name="LootScannerTab"/>
            </TabItem>
            <TabItem Header="Buff Tracker">
                <!--
                    WeakAuras-style buff watchlist.  The user picks buff names from the live
                    "currently active" + "recently seen" discovery lists; the chip strip on
                    the dashboard / overlay filters down to that picked set when the master
                    toggle is on.  Watchlist persists to
                    %LocalAppData%\MarvelHeroesComporator\buff-watchlist.json.
                -->
                <controls:BuffTrackerPanel x:Name="BuffTrackerTab"/>
            </TabItem>
            <TabItem Header="Cooldown Tracker">
                <!--
                    WeakAuras-style cooldown watchlist.  User picks abilities to track,
                    enters cooldown duration per ability; the floating cooldown overlay
                    renders each as a bare icon that fades while on cooldown and lights
                    back up when ready.  Watchlist persists to
                    %LocalAppData%\MarvelHeroesComporator\cooldown-watchlist.json.
                -->
                <controls:CooldownTrackerPanel x:Name="CooldownTrackerTab"/>
            </TabItem>
            <TabItem Header="Diagnostics">
                <!--
                    Live log viewer for triage.  Tails dps-meter.log on disk so the user (or a
                    tester) can see what the sniffer / DPS meter / splinter tracker is doing
                    without having to alt-tab to Explorer.  Filterable, copyable, bounded
                    memory.  See LogViewerPanel.cs class doc for the design notes.
                -->
                <controls:LogViewerPanel x:Name="DiagnosticsTab"/>
            </TabItem>
        </TabControl>

        <!-- ── Footer status strip ───────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="#0F0F0F" BorderBrush="#33FFFFFF"
                BorderThickness="0,1,0,0" Padding="14,4">
            <TextBlock x:Name="FooterStatus"
                       FontFamily="Segoe UI" FontSize="10"
                       Foreground="#66FFFFFF"
                       Text="Sniffer status will appear here"/>
        </Border>
    </Grid>
</Window>
