<Window x:Class="MarvelHeroes.DpsMeter.Windows.ReportViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DPS Reports"
        Width="860" Height="600"
        MinWidth="640" MinHeight="420"
        Background="#1A1A1A"
        Foreground="#CCFFFFFF"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="DarkList" TargetType="ListBox">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style x:Key="DarkListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#33FF6B00"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#44FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#55FFFFFF"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#EEFFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#44FF6B00"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FF6B00"/>
                                <Setter Property="Foreground" Value="#FFCC66"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Custom ComboBox template — WPF's default toggle button paints a Windows-themed
             white/gray surface that ignores our Background, so the closed combo looked washed
             out on the dark theme.  This template draws everything ourselves: dark background,
             bright foreground, themed chevron, themed popup. -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EEFFFFFF"/>
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0,4,0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  IsHitTestVisible="False"/>
                                <Path Grid.Column="1" x:Name="Chevron"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M 0 0 L 8 0 L 4 5 Z"
                                      Fill="#BBFFFFFF"
                                      IsHitTestVisible="False"/>
                                <ToggleButton Grid.ColumnSpan="2"
                                              Background="Transparent" BorderThickness="0"
                                              Focusable="False" ClickMode="Press"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Fade">
                                    <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            Background="#1E1E1E"
                                            BorderBrush="#55FFFFFF"
                                            BorderThickness="1"
                                            Margin="0,2,0,0"
                                            SnapsToDevicePixels="True">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#2C2C2C"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#88FFFFFF"/>
                                <Setter TargetName="Chevron"    Property="Fill"        Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#88FFCC66"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InlineEdit" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CaretBrush" Value="#FFCC66"/>
            <Setter Property="SelectionBrush" Value="#44FF6B00"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="ToolTip" Value="Click to rename this fight"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#55FFCC66"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="160"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: fight list -->
        <DockPanel Grid.Column="0" Grid.Row="0">
            <TextBlock DockPanel.Dock="Top" Text="FIGHT HISTORY"
                       FontSize="10" Foreground="#88FF6B00" Margin="0,0,0,5"
                       FontFamily="Segoe UI" FontWeight="SemiBold"/>

            <!-- Sort + filter controls -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,5">
                <ComboBox x:Name="SortCombo"
                          Style="{StaticResource DarkCombo}"
                          Margin="0,0,0,4"
                          SelectionChanged="SortCombo_SelectionChanged">
                    <ComboBoxItem Content="↓ Newest first"  Tag="date" IsSelected="True"/>
                    <ComboBoxItem Content="↓ Highest DPS"   Tag="dps"/>
                    <ComboBoxItem Content="Hero A → Z"      Tag="hero"/>
                </ComboBox>
                <ComboBox x:Name="FilterCombo"
                          Style="{StaticResource DarkCombo}"
                          SelectionChanged="FilterCombo_SelectionChanged">
                    <ComboBoxItem Content="All heroes" IsSelected="True"/>
                </ComboBox>
            </StackPanel>

            <ListBox x:Name="SnapshotList"
                     Style="{StaticResource DarkList}"
                     ItemContainerStyle="{StaticResource DarkListItem}"
                     SelectionChanged="SnapshotList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Visibility="{Binding PbBadgeVisibility}"
                                        Background="#33AAFF88" CornerRadius="2"
                                        Padding="4,0" Margin="0,0,4,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="PB" FontSize="9" FontFamily="Segoe UI"
                                               FontWeight="Bold" Foreground="#BB88FF99"/>
                                </Border>
                                <Border Visibility="{Binding AutoBadgeVisibility}"
                                        Background="#33FF6B00" CornerRadius="2"
                                        Padding="4,0" Margin="0,0,5,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="AUTO" FontSize="9" FontFamily="Segoe UI"
                                               FontWeight="SemiBold" Foreground="#BBFF6B00"/>
                                </Border>
                                <TextBlock Text="{Binding Label}" FontSize="12"
                                           FontFamily="Segoe UI" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SavedLocal}" FontSize="10"
                                           Foreground="#77FFFFFF" FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding DurationText}" FontSize="10"
                                           Foreground="#55FFFFFF" FontFamily="Segoe UI" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Grid.Row="0"
                      Width="4" HorizontalAlignment="Stretch"
                      Background="#22FFFFFF"/>

        <!-- Right: detail -->
        <Border Grid.Column="2" Grid.Row="0"
                Background="#111111" BorderBrush="#33FFFFFF" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="DetailPanel" Margin="14,12" Visibility="Collapsed">

                    <!-- Header row: editable title + date -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DetailLabel"
                                 Grid.Column="0" FontSize="17"
                                 FontFamily="Segoe UI" FontWeight="SemiBold"
                                 Foreground="#FFCC66"
                                 Style="{StaticResource InlineEdit}"
                                 KeyDown="DetailLabel_KeyDown"
                                 LostFocus="DetailLabel_LostFocus"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Bottom" Margin="8,0,0,2">
                            <Border x:Name="PbDetailBadge" Visibility="Collapsed"
                                    Background="#33AAFF88" CornerRadius="3"
                                    Padding="6,2" Margin="0,0,6,0">
                                <TextBlock Text="★ PB" FontSize="10" FontFamily="Segoe UI"
                                           FontWeight="Bold" Foreground="#BB88FF99"/>
                            </Border>
                            <TextBlock x:Name="DetailDate"
                                       FontSize="11" FontFamily="Segoe UI" Foreground="#66FFFFFF"/>
                        </StackPanel>
                    </Grid>

                    <!-- Mode / hero / stats badges -->
                    <WrapPanel Margin="0,8,0,0">
                        <Border Background="#22FF6B00" CornerRadius="3" Padding="7,3" Margin="0,0,6,4">
                            <TextBlock x:Name="DetailMode" FontSize="11" FontFamily="Segoe UI" Foreground="#BBFF6B00"/>
                        </Border>
                        <Border x:Name="DetailBossBorder" Visibility="Collapsed"
                                Background="#22D62A2A" CornerRadius="3" Padding="7,3" Margin="0,0,6,4">
                            <TextBlock x:Name="DetailBoss" FontSize="11" FontFamily="Segoe UI"
                                       FontWeight="SemiBold" Foreground="#FFCC8888"/>
                        </Border>
                        <Border Background="#1AFFFFFF" CornerRadius="3" Padding="7,3" Margin="0,0,6,4">
                            <TextBlock x:Name="DetailHero" FontSize="11" FontFamily="Segoe UI" Foreground="#AAFFFFFF"/>
                        </Border>
                        <Border Background="#1AFFFFFF" CornerRadius="3" Padding="7,3" Margin="0,0,6,4">
                            <TextBlock x:Name="DetailDps" FontSize="11" FontFamily="Segoe UI"
                                       FontWeight="SemiBold" Foreground="#EEFFFFFF"/>
                        </Border>
                        <Border Background="#1AFFFFFF" CornerRadius="3" Padding="7,3" Margin="0,0,6,4">
                            <TextBlock x:Name="DetailDuration" FontSize="11" FontFamily="Segoe UI" Foreground="#AAFFFFFF"/>
                        </Border>
                        <Border Background="#1AFFFFFF" CornerRadius="3" Padding="7,3" Margin="0,0,0,4">
                            <TextBlock x:Name="DetailMaxHit" FontSize="11" FontFamily="Segoe UI" Foreground="#AAFFFFFF"/>
                        </Border>
                    </WrapPanel>

                    <!-- Sparkline -->
                    <Border x:Name="SparkBorder" Visibility="Collapsed"
                            Background="#0AFFFFFF" CornerRadius="3"
                            Margin="0,10,0,0" Padding="6,6,6,4">
                        <StackPanel>
                            <TextBlock Text="DPS OVER FIGHT" FontSize="9" FontFamily="Segoe UI"
                                       FontWeight="SemiBold" Foreground="#55FF6B00" Margin="0,0,0,4"/>
                            <Canvas x:Name="SparkCanvas" Height="48"
                                    SizeChanged="SparkCanvas_SizeChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- Leaderboard section -->
                    <TextBlock Text="LEADERBOARD" Margin="0,14,0,4"
                               FontSize="10" Foreground="#88FF6B00"
                               FontFamily="Segoe UI" FontWeight="SemiBold"/>
                    <TextBlock Text="Click a player to see their abilities"
                               FontSize="9" FontFamily="Segoe UI" Foreground="#44FFFFFF"
                               Margin="0,0,0,4"/>
                    <Grid Margin="4,0,4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="HERO" FontSize="9" FontFamily="Segoe UI"
                                   FontWeight="SemiBold" Foreground="#44FF6B00" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="DPS"   Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="2" Text="TOTAL" Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="3" Text="%"     Style="{StaticResource ColHeader}"/>
                    </Grid>
                    <ListBox x:Name="LeaderboardItems"
                             Background="Transparent" BorderThickness="0"
                             SelectionChanged="LeaderboardItems_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#18FF6B00"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="24" Margin="0,1" Cursor="Hand">
                                    <Rectangle HorizontalAlignment="Left"
                                               Height="24" RadiusX="3" RadiusY="3"
                                               Width="{Binding BarWidth}" Fill="{Binding BarFill}"/>
                                    <Grid Margin="4,0,4,0" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                   FontFamily="Segoe UI" FontSize="12"
                                                   Foreground="{Binding TextColor}"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DpsText}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="{Binding TextColor}" TextAlignment="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TotalText}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="{Binding TextColor}" TextAlignment="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding PctText}"
                                                   FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{Binding TextColor}" TextAlignment="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Ability breakdown section (collapsed when no data) -->
                    <StackPanel x:Name="PowerSectionHeader" Visibility="Collapsed">
                        <TextBlock x:Name="PowerSectionTitle" Text="MY ABILITIES" Margin="0,16,0,4"
                                   FontSize="10" Foreground="#88FF6B00"
                                   FontFamily="Segoe UI" FontWeight="SemiBold"/>
                        <Grid Margin="4,0,4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="66"/>
                                <ColumnDefinition Width="66"/>
                                <ColumnDefinition Width="66"/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ABILITY" FontSize="9" FontFamily="Segoe UI"
                                       FontWeight="SemiBold" Foreground="#44FF6B00" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="HITS"    Style="{StaticResource ColHeader}"/>
                            <TextBlock Grid.Column="2" Text="AVG HIT" Style="{StaticResource ColHeader}"/>
                            <TextBlock Grid.Column="3" Text="MAX HIT" Style="{StaticResource ColHeader}"/>
                            <TextBlock Grid.Column="4" Text="TOTAL"   Style="{StaticResource ColHeader}"/>
                            <TextBlock Grid.Column="5" Text="%"       Style="{StaticResource ColHeader}"/>
                        </Grid>
                        <ItemsControl x:Name="PowerItems" Margin="0,2,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="22" Margin="0,1">
                                        <Rectangle HorizontalAlignment="Left"
                                                   Height="22" RadiusX="3" RadiusY="3"
                                                   Width="{Binding BarWidth}" Fill="{Binding BarFill}"/>
                                        <Grid Margin="4,0,4,0" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="66"/>
                                                <ColumnDefinition Width="66"/>
                                                <ColumnDefinition Width="66"/>
                                                <ColumnDefinition Width="42"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontFamily="Segoe UI" FontSize="12"
                                                       Foreground="{Binding TextColor}"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding HitsText}"
                                                       FontFamily="Segoe UI" FontSize="10"
                                                       Foreground="#77FFFFFF" TextAlignment="Right"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding AvgHitText}"
                                                       FontFamily="Segoe UI" FontSize="10"
                                                       Foreground="#AAFFFFFF" TextAlignment="Right"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding MaxHitText}"
                                                       FontFamily="Segoe UI" FontSize="10"
                                                       Foreground="#88FFFFFF" TextAlignment="Right"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding TotalText}"
                                                       FontFamily="Segoe UI" FontSize="10"
                                                       Foreground="#77FFFFFF" TextAlignment="Right"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="{Binding PctText}"
                                                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding TextColor}" TextAlignment="Right"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Totals summary row -->
                        <Border x:Name="PowerTotalsRow" Visibility="Collapsed"
                                BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0"
                                Margin="0,3,0,0" Padding="0,4,0,0">
                            <Grid Margin="4,0,4,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="66"/>
                                    <ColumnDefinition Width="66"/>
                                    <ColumnDefinition Width="66"/>
                                    <ColumnDefinition Width="42"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TOTAL" FontFamily="Segoe UI"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#88FFFFFF" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="TotalsHits"
                                           FontFamily="Segoe UI" FontSize="10"
                                           Foreground="#66FFFFFF" TextAlignment="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TotalsAvg"
                                           FontFamily="Segoe UI" FontSize="10"
                                           Foreground="#88FFFFFF" TextAlignment="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" x:Name="TotalsMax"
                                           FontFamily="Segoe UI" FontSize="10"
                                           Foreground="#77FFFFFF" TextAlignment="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" x:Name="TotalsTotal"
                                           FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#88FFFFFF" TextAlignment="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="100%"
                                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#77FFFFFF" TextAlignment="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,6,0,0">
            <Button x:Name="CopyButton" Content="Copy to clipboard"
                    Style="{StaticResource DarkButton}"
                    IsEnabled="False"
                    Click="CopyButton_Click" Margin="0,0,8,0"/>
            <Button x:Name="DeleteButton" Content="Delete snapshot"
                    Style="{StaticResource DarkButton}"
                    IsEnabled="False"
                    Click="DeleteButton_Click" Margin="0,0,8,0"/>
            <Button Content="Close"
                    Style="{StaticResource DarkButton}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
