<Window x:Class="MarvelHeroes.DpsMeter.Windows.ReportViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MarvelHeroes.DpsMeter.Controls"
        Title="DPS Reports"
        Width="860" Height="600"
        MinWidth="640" MinHeight="420"
        Background="#1A1A1A"
        Foreground="#CCFFFFFF"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <!--
        Thin wrapper around the new ReportViewerPanel UserControl.  The panel owns every bit
        of the report-viewer UI; this window exists so the right-click "View reports" menu
        path still has somewhere to open without the main app being involved.  The main
        app's Reports tab uses the same panel directly with ShowCloseButton=false.
    -->
    <controls:ReportViewerPanel x:Name="Panel" ShowCloseButton="True"/>
</Window>
