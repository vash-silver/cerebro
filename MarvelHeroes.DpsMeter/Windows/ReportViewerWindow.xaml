<Window x:Class="MarvelHeroes.DpsMeter.Windows.ReportViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DPS Reports"
        Width="660" Height="480"
        MinWidth="480" MinHeight="320"
        Background="#1A1A1A"
        Foreground="#CCFFFFFF"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="DarkList" TargetType="ListBox">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style x:Key="DarkListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#33FF6B00"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="140"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: report list -->
        <DockPanel Grid.Column="0" Grid.Row="0">
            <TextBlock DockPanel.Dock="Top" Text="FIGHT HISTORY"
                       FontSize="10" Foreground="#88FF6B00" Margin="0,0,0,4"
                       FontFamily="Segoe UI" FontWeight="SemiBold"/>
            <ListBox x:Name="SnapshotList"
                     Style="{StaticResource DarkList}"
                     ItemContainerStyle="{StaticResource DarkListItem}"
                     SelectionChanged="SnapshotList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Visibility="{Binding AutoBadgeVisibility}"
                                        Background="#33FF6B00" CornerRadius="2"
                                        Padding="4,0" Margin="0,0,5,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="AUTO" FontSize="9" FontFamily="Segoe UI"
                                               FontWeight="SemiBold" Foreground="#BBFF6B00"/>
                                </Border>
                                <TextBlock Text="{Binding Label}" FontSize="12"
                                           FontFamily="Segoe UI" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SavedLocal}" FontSize="10"
                                       Foreground="#88FFFFFF" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Grid.Row="0"
                      Width="4" HorizontalAlignment="Stretch"
                      Background="#22FFFFFF"/>

        <!-- Right: detail -->
        <Border Grid.Column="2" Grid.Row="0"
                Background="#111111" BorderBrush="#33FFFFFF" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="DetailPanel" Margin="12,10" Visibility="Collapsed">

                    <!-- Header row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DetailLabel"
                                   Grid.Column="0" FontSize="16"
                                   FontFamily="Segoe UI" FontWeight="SemiBold"
                                   Foreground="#FFCC66" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="DetailDate"
                                   Grid.Column="1" FontSize="11"
                                   FontFamily="Segoe UI" Foreground="#88FFFFFF"
                                   VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                    </Grid>

                    <!-- Mode / hero / stats row -->
                    <WrapPanel Margin="0,6,0,0">
                        <Border Background="#22FF6B00" CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                            <TextBlock x:Name="DetailMode" FontSize="11" FontFamily="Segoe UI" Foreground="#BBFF6B00"/>
                        </Border>
                        <Border Background="#22FFFFFF" CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                            <TextBlock x:Name="DetailHero" FontSize="11" FontFamily="Segoe UI" Foreground="#CCFFFFFF"/>
                        </Border>
                        <Border Background="#22FFFFFF" CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                            <TextBlock x:Name="DetailDps" FontSize="11" FontFamily="Segoe UI" Foreground="#CCFFFFFF"/>
                        </Border>
                        <Border Background="#22FFFFFF" CornerRadius="3" Padding="6,2">
                            <TextBlock x:Name="DetailMaxHit" FontSize="11" FontFamily="Segoe UI" Foreground="#CCFFFFFF"/>
                        </Border>
                    </WrapPanel>

                    <!-- Leaderboard -->
                    <TextBlock Text="LEADERBOARD" Margin="0,14,0,4"
                               FontSize="10" Foreground="#88FF6B00"
                               FontFamily="Segoe UI" FontWeight="SemiBold"/>
                    <ItemsControl x:Name="LeaderboardItems" Margin="0,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="22" Margin="0,1">
                                    <Rectangle x:Name="LbBar" HorizontalAlignment="Left"
                                               Height="22" RadiusX="3" RadiusY="3"
                                               Width="{Binding BarWidth}"
                                               Fill="{Binding BarFill}"/>
                                    <Grid Margin="4,0,4,0" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                   FontFamily="Segoe UI" FontSize="12"
                                                   Foreground="{Binding TextColor}"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DpsText}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="{Binding TextColor}" TextAlignment="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TotalText}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="{Binding TextColor}" TextAlignment="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding PctText}"
                                                   FontFamily="Segoe UI" FontSize="12"
                                                   Foreground="{Binding TextColor}" TextAlignment="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Power breakdown -->
                    <TextBlock x:Name="PowerSectionHeader" Text="MY POWERS" Margin="0,14,0,4"
                               FontSize="10" Foreground="#88FF6B00"
                               FontFamily="Segoe UI" FontWeight="SemiBold"
                               Visibility="Collapsed"/>
                    <ItemsControl x:Name="PowerItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="20" Margin="0,1">
                                    <Rectangle HorizontalAlignment="Left"
                                               Height="20" RadiusX="3" RadiusY="3"
                                               Width="{Binding BarWidth}"
                                               Fill="{Binding BarFill}"/>
                                    <Grid Margin="4,0,4,0" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="{Binding TextColor}"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding HitsText}"
                                                   FontFamily="Segoe UI" FontSize="10"
                                                   Foreground="#88FFFFFF" TextAlignment="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TotalText}"
                                                   FontFamily="Segoe UI" FontSize="10"
                                                   Foreground="#88FFFFFF" TextAlignment="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding PctText}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="{Binding TextColor}" TextAlignment="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,6,0,0">
            <Button x:Name="DeleteButton" Content="Delete snapshot"
                    Style="{StaticResource DarkButton}"
                    IsEnabled="False"
                    Click="DeleteButton_Click" Margin="0,0,8,0"/>
            <Button Content="Close"
                    Style="{StaticResource DarkButton}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
